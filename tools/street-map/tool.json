{
  "id": "street-map",
  "name": "Street Map",
  "description": "A clean, vector street-block map of a city — pan and zoom to frame the exact ~5-block view you want. Works fully offline.",
  "a11yLabel": "Street map centered on {{city}}",
  "version": "0.3.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "tags": ["map", "street", "city", "location", "vector", "offline", "osm"],
  "render": {
    "width": 900,
    "height": 900,
    "formats": ["svg", "pdf", "pdf-cmyk", "png"],
    "actions": ["copy", "download", "save"],
    "transparentBg": false
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "city",
      "label": "City",
      "type": "select",
      "default": "nuremberg",
      "help": "Add more cities offline with scripts/build-street-clips.js — no API at render time.",
      "options": [
        { "value": "amsterdam", "label": "Amsterdam" },
        { "value": "athens", "label": "Athens" },
        { "value": "bangkok", "label": "Bangkok" },
        { "value": "barcelona", "label": "Barcelona" },
        { "value": "beijing", "label": "Beijing" },
        { "value": "berlin", "label": "Berlin" },
        { "value": "brisbane", "label": "Brisbane" },
        { "value": "brussels", "label": "Brussels" },
        { "value": "budapest", "label": "Budapest" },
        { "value": "buenosaires", "label": "Buenos Aires" },
        { "value": "cairo", "label": "Cairo" },
        { "value": "capetown", "label": "Cape Town" },
        { "value": "chicago", "label": "Chicago" },
        { "value": "copenhagen", "label": "Copenhagen" },
        { "value": "delhi", "label": "Delhi" },
        { "value": "dubai", "label": "Dubai" },
        { "value": "dublin", "label": "Dublin" },
        { "value": "edinburgh", "label": "Edinburgh" },
        { "value": "helsinki", "label": "Helsinki" },
        { "value": "hongkong", "label": "Hong Kong" },
        { "value": "istanbul", "label": "Istanbul" },
        { "value": "kualalumpur", "label": "Kuala Lumpur" },
        { "value": "lisbon", "label": "Lisbon" },
        { "value": "london", "label": "London" },
        { "value": "losangeles", "label": "Los Angeles" },
        { "value": "madrid", "label": "Madrid" },
        { "value": "mexicocity", "label": "Mexico City" },
        { "value": "moscow", "label": "Moscow" },
        { "value": "mumbai", "label": "Mumbai" },
        { "value": "munich", "label": "Munich" },
        { "value": "newyork", "label": "New York" },
        { "value": "noosa", "label": "Noosa" },
        { "value": "nuremberg", "label": "Nuremberg" },
        { "value": "oslo", "label": "Oslo" },
        { "value": "paris", "label": "Paris" },
        { "value": "prague", "label": "Prague" },
        { "value": "provo", "label": "Provo" },
        { "value": "riodejaneiro", "label": "Rio de Janeiro" },
        { "value": "rome", "label": "Rome" },
        { "value": "sanfrancisco", "label": "San Francisco" },
        { "value": "saopaulo", "label": "São Paulo" },
        { "value": "seoul", "label": "Seoul" },
        { "value": "shanghai", "label": "Shanghai" },
        { "value": "singapore", "label": "Singapore" },
        { "value": "stockholm", "label": "Stockholm" },
        { "value": "sydney", "label": "Sydney" },
        { "value": "tokyo", "label": "Tokyo" },
        { "value": "toronto", "label": "Toronto" },
        { "value": "vancouver", "label": "Vancouver" },
        { "value": "vienna", "label": "Vienna" },
        { "value": "warsaw", "label": "Warsaw" },
        { "value": "washington", "label": "Washington, DC" },
        { "value": "zurich", "label": "Zurich" }
      ]
    },
    {
      "id": "theme",
      "label": "Theme",
      "type": "select",
      "default": "light",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" }
      ]
    },
    {
      "id": "roadWeight",
      "label": "Road weight",
      "type": "number",
      "display": "slider",
      "default": 1,
      "min": 0.25,
      "max": 9,
      "step": 0.01,
      "help": "Stroke thickness of the road lines."
    },
    {
      "id": "showWater",
      "label": "Show water",
      "type": "boolean",
      "default": true
    },
    {
      "id": "roadColor",
      "label": "Road color",
      "type": "color",
      "default": "",
      "help": "Leave empty to use the theme's default."
    },
    {
      "id": "waterColor",
      "label": "Water color",
      "type": "color",
      "default": "",
      "help": "Leave empty to use the theme's default."
    },
    {
      "id": "background",
      "label": "Background",
      "type": "color",
      "default": "",
      "help": "Leave empty to use the theme's default."
    },
    {
      "id": "view",
      "label": "Map viewport",
      "type": "text",
      "default": "",
      "placeholder": "pan & zoom to set",
      "help": "Auto-saved when you pan or zoom. Clear to reset to the default framing."
    }
  ]
}
