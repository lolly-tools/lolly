{
  "id": "color-block",
  "name": "Color Block",
  "description": "Stack typed colour blocks — heading, text, headshot, logo — and they auto-compose into a grid that fills any frame.",
  "a11yLabel": "Colour-block composition",
  "version": "1.0.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "everyone",
  "tags": ["layout", "blocks", "grid", "responsive", "poster", "social", "composition"],
  "render": {
    "width": 1920,
    "height": 1080,
    "formats": ["png", "jpg", "webp", "pdf", "pdf-cmyk", "cmyk-tiff", "svg", "html"],
    "actions": ["copy", "download", "save"]
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "blocks",
      "label": "Blocks",
      "type": "blocks",
      "help": "Add blocks in any order — the layout repacks into a grid that fills the frame. Each type can be added once; blanks are unlimited.",
      "addMenu": { "field": "kind", "label": "Add block" },
      "fields": [
        {
          "id": "kind",
          "label": "Type",
          "type": "select",
          "options": [
            { "value": "heading",    "label": "Heading" },
            { "value": "subheading", "label": "Subheading" },
            { "value": "body",       "label": "Body text" },
            { "value": "cta",        "label": "Call to action" },
            { "value": "headshot",   "label": "Headshot" },
            { "value": "logo",       "label": "Logo" },
            { "value": "blank",      "label": "Blank", "repeatable": true }
          ],
          "default": "heading"
        },
        {
          "id": "bgColor",
          "label": "Background",
          "type": "color",
          "default": ""
        },
        {
          "id": "fgColor",
          "label": "Text colour",
          "type": "color",
          "default": "",
          "showFor": ["heading", "subheading", "body", "cta"]
        },
        {
          "id": "text",
          "label": "Text",
          "type": "text",
          "default": "",
          "placeholder": "Type here…",
          "showFor": ["heading", "subheading", "body", "cta"],
          "multilineFor": ["body"]
        },
        {
          "id": "scale",
          "label": "Text scale",
          "type": "number",
          "display": "slider",
          "min": 0.3, "max": 2.5, "step": 0.05, "default": 1,
          "showFor": ["heading", "subheading", "body", "cta", "headshot", "blank"]
        },
        {
          "id": "weight",
          "label": "Font weight",
          "type": "number",
          "display": "slider",
          "min": 100, "max": 900, "step": 100, "default": 400,
          "showFor": ["heading", "subheading", "body", "cta"]
        },
        {
          "id": "ctaStyle",
          "label": "Button style",
          "type": "select",
          "default": "none",
          "showFor": ["cta"],
          "options": [
            { "value": "none",  "label": "None — plain text" },
            { "value": "arrow", "label": "Arrow →" },
            { "value": "pill",  "label": "Pill" },
            { "value": "caret", "label": "Caret _" }
          ]
        },
        {
          "id": "logoOrient",
          "label": "Logo lockup",
          "type": "select",
          "default": "horizontal",
          "showFor": ["logo"],
          "options": [
            { "value": "horizontal", "label": "Horizontal" },
            { "value": "stacked",    "label": "Stacked" }
          ]
        },
        {
          "id": "logoColor",
          "label": "Logo colour",
          "type": "select",
          "default": "mono",
          "showFor": ["logo"],
          "options": [
            { "value": "mono",  "label": "Mono — black / white" },
            { "value": "green", "label": "Green" }
          ]
        },
        {
          "id": "logoSize",
          "label": "Logo size",
          "type": "number",
          "display": "slider",
          "help": "Share of the cell the mark fills — the rest is even clearspace.",
          "min": 0.4, "max": 0.95, "step": 0.05, "default": 0.8,
          "showFor": ["logo"]
        },
        {
          "id": "bgImage",
          "label": "Image",
          "type": "asset",
          "assetType": "raster",
          "allowUpload": true,
          "showFor": ["heading", "subheading", "body", "cta", "headshot", "blank"]
        },
        {
          "id": "bgX",
          "label": "Image X",
          "type": "number",
          "display": "slider",
          "min": 0, "max": 100, "step": 1, "default": 50,
          "showFor": ["heading", "subheading", "body", "cta", "headshot", "blank"]
        },
        {
          "id": "bgY",
          "label": "Image Y",
          "type": "number",
          "display": "slider",
          "min": 0, "max": 100, "step": 1, "default": 50,
          "showFor": ["heading", "subheading", "body", "cta", "headshot", "blank"]
        },
        {
          "id": "bgZoom",
          "label": "Image zoom",
          "type": "number",
          "display": "slider",
          "min": 100, "max": 400, "step": 1, "default": 100,
          "showFor": ["heading", "subheading", "body", "cta", "headshot", "blank"]
        }
      ],
      "default": [
        { "kind": "logo",       "logoOrient": "horizontal", "logoColor": "mono", "bgColor": "#0c322c", "logoSize": 0.8 },
        { "kind": "heading",    "text": "Build once.",   "bgColor": "#30ba78", "scale": 1, "weight": 700 },
        { "kind": "subheading", "text": "Ship anywhere.", "bgColor": "#90ebcd", "scale": 1, "weight": 400 },
        { "kind": "blank",      "text": "",              "bgColor": "#01564a", "scale": 1, "weight": 400 }
      ]
    }
  ]
}
