{
  "id": "color-block",
  "name": "Color Block",
  "description": "Stack typed colour blocks — heading, text, headshot — and they auto-compose into a grid that fills any frame.",
  "a11yLabel": "Colour-block composition",
  "version": "1.0.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "everyone",
  "tags": ["layout", "blocks", "grid", "responsive", "poster", "social", "composition"],
  "render": {
    "width": 1920,
    "height": 1080,
    "formats": ["png", "jpg", "webp", "pdf", "pdf-cmyk", "cmyk-tiff", "svg", "html"],
    "actions": ["copy", "download", "save"]
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "logo",
      "label": "Logo",
      "type": "select",
      "default": "top-right",
      "options": [
        { "value": "none",         "label": "None" },
        { "value": "top-left",     "label": "Top left" },
        { "value": "top-right",    "label": "Top right" },
        { "value": "bottom-left",  "label": "Bottom left" },
        { "value": "bottom-right", "label": "Bottom right" }
      ],
      "help": "Drop the SUSE logo in a corner. Mono mark, white or black — chosen automatically from the block behind it."
    },
    {
      "id": "blocks",
      "label": "Blocks",
      "type": "blocks",
      "help": "Add blocks in any order — the layout repacks into a grid that fills the frame. Each type can be added once; blanks are unlimited.",
      "addMenu": { "field": "kind", "label": "Add block" },
      "fields": [
        {
          "id": "kind",
          "label": "Type",
          "type": "select",
          "options": [
            { "value": "heading",    "label": "Heading" },
            { "value": "subheading", "label": "Subheading" },
            { "value": "body",       "label": "Body text" },
            { "value": "cta",        "label": "Call to action" },
            { "value": "headshot",   "label": "Headshot" },
            { "value": "blank",      "label": "Blank", "repeatable": true }
          ],
          "default": "heading"
        },
        {
          "id": "bgColor",
          "label": "Background",
          "type": "color",
          "default": ""
        },
        {
          "id": "fgColor",
          "label": "Text colour",
          "type": "color",
          "default": "",
          "showFor": ["heading", "subheading", "body", "cta"]
        },
        {
          "id": "text",
          "label": "Text",
          "type": "text",
          "default": "",
          "placeholder": "Type here…",
          "showFor": ["heading", "subheading", "body", "cta"]
        },
        {
          "id": "ctaStyle",
          "label": "Button style",
          "type": "select",
          "default": "none",
          "showFor": ["cta"],
          "options": [
            { "value": "none",  "label": "None — plain text" },
            { "value": "arrow", "label": "Arrow →" },
            { "value": "pill",  "label": "Pill" },
            { "value": "caret", "label": "Caret _" }
          ]
        },
        {
          "id": "bgImage",
          "label": "Image",
          "type": "asset",
          "assetType": "raster",
          "allowUpload": true
        },
        {
          "id": "bgX",
          "label": "Image X",
          "type": "number",
          "display": "slider",
          "min": 0, "max": 100, "step": 1, "default": 50
        },
        {
          "id": "bgY",
          "label": "Image Y",
          "type": "number",
          "display": "slider",
          "min": 0, "max": 100, "step": 1, "default": 50
        },
        {
          "id": "bgZoom",
          "label": "Image zoom",
          "type": "number",
          "display": "slider",
          "min": 100, "max": 400, "step": 1, "default": 100
        },
        {
          "id": "scale",
          "label": "Scale",
          "type": "number",
          "display": "slider",
          "min": 0.3, "max": 2.5, "step": 0.05, "default": 1
        },
        {
          "id": "weight",
          "label": "Weight",
          "type": "number",
          "display": "slider",
          "min": 100, "max": 900, "step": 100, "default": 400,
          "showFor": ["heading", "subheading", "body", "cta"]
        }
      ],
      "default": [
        { "kind": "heading",    "text": "Build once.",   "bgColor": "#0c322c", "scale": 1, "weight": 700 },
        { "kind": "subheading", "text": "Ship anywhere.", "bgColor": "#30ba78", "scale": 1, "weight": 400 },
        { "kind": "blank",      "text": "",              "bgColor": "#90ebcd", "scale": 1, "weight": 400 }
      ]
    }
  ]
}
