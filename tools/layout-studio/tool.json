{
  "id": "layout-studio",
  "name": "Layout Studio",
  "version": "1.0.0",
  "engineVersion": "^1.4.0",
  "status": "community",
  "category": "utility",
  "tags": ["canvas", "layout", "wysiwyg", "editor", "poster", "compose", "design", "free-form"],
  "render": {
    "width": 1080,
    "height": 1080,
    "formats": ["png", "svg", "pdf", "jpg", "webp"],
    "actions": ["copy", "download", "save", "share"],
    "layout": "editor",
    "transparentBg": true,
    "printMarks": false
  },
  "hooks": { "onInit": true, "onInput": true, "beforeExport": true },
  "inputs": [
    {
      "id": "background",
      "type": "color",
      "label": "Canvas background",
      "default": "#ffffff"
    },
    {
      "id": "boxes",
      "type": "blocks",
      "label": "Boxes",
      "labelledFields": true,
      "addMenu": { "field": "kind", "label": "Add box" },
      "canvas": {
        "idField": "id",
        "xField": "x",
        "yField": "y",
        "wField": "w",
        "hField": "h",
        "rotationField": "rot",
        "shapeField": "shape",
        "radiusField": "radius",
        "fillField": "bg",
        "opacityField": "opacity",
        "imageField": "image",
        "textField": "text",
        "textColorField": "fg",
        "fontSizeField": "fontSize",
        "alignField": "align",
        "valignField": "valign",
        "weightField": "weight",
        "fitField": "fit",
        "blendField": "blend",
        "groupField": "group",
        "clipField": "clip",
        "minSize": 8,
        "addKinds": [
          { "id": "box", "label": "Box", "seed": { "kind": "box", "bg": "#30BA78", "shape": "rounded", "text": "" } },
          { "id": "text", "label": "Text", "seed": { "kind": "text", "bg": "", "shape": "rect", "text": "Text", "fg": "#0c322c", "fontSize": 64, "valign": "top" } },
          { "id": "image", "label": "Image", "seed": { "kind": "image", "bg": "#eef1f0", "shape": "rounded", "fit": "cover", "text": "" } }
        ]
      },
      "fields": [
        { "id": "id", "type": "text" },
        {
          "id": "kind",
          "type": "select",
          "label": "Kind",
          "default": "box",
          "options": [
            { "value": "box", "label": "Box", "repeatable": true },
            { "value": "text", "label": "Text", "repeatable": true },
            { "value": "image", "label": "Image", "repeatable": true }
          ]
        },
        { "id": "x", "type": "number", "label": "X", "default": 120 },
        { "id": "y", "type": "number", "label": "Y", "default": 120 },
        { "id": "w", "type": "number", "label": "Width", "default": 320, "min": 1 },
        { "id": "h", "type": "number", "label": "Height", "default": 200, "min": 1 },
        { "id": "rot", "type": "number", "label": "Rotation", "default": 0, "min": -180, "max": 180 },
        {
          "id": "shape",
          "type": "select",
          "label": "Shape",
          "default": "rect",
          "options": [
            { "value": "rect", "label": "Rectangle" },
            { "value": "rounded", "label": "Rounded" },
            { "value": "pill", "label": "Pill" },
            { "value": "ellipse", "label": "Ellipse" }
          ]
        },
        { "id": "radius", "type": "number", "label": "Corner radius", "default": 16, "min": 0, "showIf": { "shape": "rounded" } },
        { "id": "bg", "type": "color", "label": "Fill", "default": "#30BA78" },
        { "id": "opacity", "type": "number", "label": "Opacity", "default": 100, "min": 0, "max": 100, "display": "slider" },
        { "id": "image", "type": "asset", "label": "Image", "assetType": "raster", "allowUpload": true },
        {
          "id": "fit",
          "type": "select",
          "label": "Image fit",
          "default": "cover",
          "options": [
            { "value": "cover", "label": "Cover (crop to fill)" },
            { "value": "contain", "label": "Contain (fit inside)" },
            { "value": "fill", "label": "Stretch" }
          ]
        },
        {
          "id": "blend",
          "type": "select",
          "label": "Blend mode",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "multiply", "label": "Multiply" },
            { "value": "screen", "label": "Screen" },
            { "value": "overlay", "label": "Overlay" },
            { "value": "darken", "label": "Darken" },
            { "value": "lighten", "label": "Lighten" },
            { "value": "color-dodge", "label": "Colour dodge" },
            { "value": "color-burn", "label": "Colour burn" },
            { "value": "hard-light", "label": "Hard light" },
            { "value": "soft-light", "label": "Soft light" },
            { "value": "difference", "label": "Difference" },
            { "value": "exclusion", "label": "Exclusion" },
            { "value": "hue", "label": "Hue" },
            { "value": "saturation", "label": "Saturation" },
            { "value": "color", "label": "Colour" },
            { "value": "luminosity", "label": "Luminosity" }
          ]
        },
        { "id": "text", "type": "text", "label": "Text", "default": "", "multilineFor": ["box", "text", "image"], "rows": 3 },
        { "id": "fg", "type": "color", "label": "Text colour", "default": "#0c322c" },
        { "id": "fontSize", "type": "number", "label": "Text size", "default": 48, "min": 4 },
        {
          "id": "align",
          "type": "select",
          "label": "Align",
          "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Centre" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "id": "valign",
          "type": "select",
          "label": "Vertical",
          "default": "middle",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "id": "weight",
          "type": "select",
          "label": "Weight",
          "default": "700",
          "options": [
            { "value": "400", "label": "Regular" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extrabold" }
          ]
        },
        { "id": "group", "type": "text", "label": "Group", "default": "" },
        { "id": "clip", "type": "text", "label": "Clip to", "default": "" }
      ],
      "default": [
        { "id": "p1", "kind": "box", "x": 90, "y": 90, "w": 900, "h": 900, "rot": 0, "shape": "rounded", "radius": 44, "bg": "#f3f5f4", "opacity": 100, "text": "" },
        { "id": "a1", "kind": "box", "x": 150, "y": 170, "w": 300, "h": 300, "rot": 0, "shape": "ellipse", "bg": "#30BA78", "opacity": 100, "text": "" },
        { "id": "a2", "kind": "box", "x": 560, "y": 250, "w": 260, "h": 260, "rot": 12, "shape": "rounded", "radius": 28, "bg": "#2453ff", "opacity": 100, "text": "" },
        { "id": "t1", "kind": "text", "x": 150, "y": 560, "w": 780, "h": 210, "rot": 0, "shape": "rect", "bg": "", "opacity": 100, "text": "Layout Studio", "fg": "#0c322c", "fontSize": 118, "align": "left", "valign": "top", "weight": "800" },
        { "id": "t2", "kind": "text", "x": 152, "y": 720, "w": 780, "h": 150, "rot": 0, "shape": "rect", "bg": "", "opacity": 100, "text": "Drag to move · corner to resize · ✦ to spin", "fg": "#4b615a", "fontSize": 40, "align": "left", "valign": "top", "weight": "400" }
      ]
    }
  ]
}
