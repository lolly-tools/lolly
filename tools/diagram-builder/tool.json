{
  "id": "diagram-builder",
  "name": "Diagram Builder",
  "description": "Build org charts, layered \"layercake\" architecture diagrams, and process flowcharts — from visual cards, a typed text description, or ASCII art you draw. Clean export-safe output in the SUSE palette and type.",
  "a11yLabel": "{{default title \"Untitled\"}} — {{diagramType}} diagram",
  "version": "1.3.0",
  "engineVersion": "^1.0.0",
  "status": "experimental",
  "category": "designer",
  "tags": ["diagram", "org-chart", "org chart", "architecture", "layercake", "flowchart", "process", "hierarchy", "cards", "arrows", "ascii", "text", "mermaid"],
  "render": {
    "width": 1600,
    "height": 1000,
    "formats": ["svg", "pdf", "png"],
    "actions": ["copy", "download", "save"],
    "transparentBg": true
  },
  "hooks": {
    "onInit": true,
    "onInput": true
  },
  "inputs": [
    {
      "id": "diagramType",
      "label": "Diagram type",
      "type": "select",
      "default": "org",
      "help": "Org builds a top-down tree from each card's “Reports to”. Layercake stacks cards into horizontal layer bands. Process lays steps out along their flow arrows.",
      "options": [
        { "value": "org", "label": "Org chart (hierarchy)" },
        { "value": "layercake", "label": "Layercake (layered architecture)" },
        { "value": "process", "label": "Process (flowchart)" }
      ]
    },
    {
      "id": "source",
      "label": "Build from",
      "type": "select",
      "default": "visual",
      "help": "Visual edits cards as form rows. Text renders a typed diagram description. ASCII art traces boxes you draw with + - | characters.",
      "options": [
        { "value": "visual", "label": "Visual editor" },
        { "value": "text", "label": "Text (type it)" },
        { "value": "ascii", "label": "ASCII art (draw it)" }
      ]
    },
    {
      "id": "title",
      "label": "Title",
      "type": "text",
      "default": "",
      "placeholder": "Optional heading shown above the diagram"
    },
    {
      "id": "dsl",
      "label": "Diagram text",
      "type": "longtext",
      "showIf": { "source": "text" },
      "help": "Org: indent for hierarchy. Layercake: “# Layer” headings with cards listed below. Process: “A -> B -> C” (add “ : label” for an arrow label). “::” adds a card subtitle; “@ https://…/logo.png” adds an image to a card; “//” starts a comment.",
      "default": "CEO\n  CTO :: Technology\n    Eng Lead\n    QA Lead\n  CFO :: Finance\n  COO :: Operations"
    },
    {
      "id": "asciiArt",
      "label": "ASCII art",
      "type": "longtext",
      "showIf": { "source": "ascii" },
      "help": "Draw boxes with + - | and connect them with - | and arrowheads > < ^ v. Keep each box's | sides lined up with its +---+ borders. The first line inside a box is its title, the rest its subtitle, and a line of “@ https://…/logo.png” adds an image. Your layout is preserved — we just render it as clean cards.",
      "default": "+--------+          +-------+\n| Client |--------->|  API  |\n+--------+          +-------+\n                        |\n                        v\n                  +----------+\n                  | Database |\n                  +----------+"
    },
    {
      "id": "flowDir",
      "label": "Flow direction",
      "type": "select",
      "default": "down",
      "showIf": { "diagramType": "process" },
      "help": "Which way a process flows between steps.",
      "options": [
        { "value": "down", "label": "Top to bottom" },
        { "value": "right", "label": "Left to right" }
      ]
    },
    {
      "id": "nodes",
      "label": "Cards",
      "type": "blocks",
      "labelledFields": true,
      "showIf": { "source": "visual" },
      "help": "One card per row. Give each a short ID so arrows and reporting lines can point at it. Drag to reorder — order sets sibling order (org) and left-to-right order within a layer (layercake).",
      "addMenu": { "field": "shape", "label": "Add card" },
      "fields": [
        {
          "id": "shape",
          "label": "Shape",
          "type": "select",
          "default": "rounded",
          "options": [
            { "value": "box", "label": "Box", "repeatable": true },
            { "value": "rounded", "label": "Rounded", "repeatable": true },
            { "value": "pill", "label": "Pill", "repeatable": true }
          ]
        },
        { "id": "nodeId", "label": "ID", "type": "text", "placeholder": "e.g. ceo", "help": "Short unique handle. Auto-derived from the label if left blank." },
        { "id": "label", "label": "Label", "type": "text", "placeholder": "Card text" },
        { "id": "detail", "label": "Detail", "type": "text", "placeholder": "Subtitle (optional)" },
        { "id": "image", "label": "Image", "type": "asset", "assetType": "any", "allowUpload": true, "help": "Optional headshot, icon, or product logo shown on the card. Upload your own or pick from the library." },
        { "id": "parent", "label": "Reports to (ID)", "type": "text", "placeholder": "ID of the card above", "showIf": { "diagramType": "org" }, "help": "Leave blank for a top-level card." },
        { "id": "layer", "label": "Layer (ID)", "type": "text", "placeholder": "ID of a layer below", "showIf": { "diagramType": "layercake" } },
        { "id": "fill", "label": "Card colour", "type": "color", "default": "", "help": "Overrides the global card fill for this card only." }
      ],
      "default": [
        { "shape": "rounded", "nodeId": "web", "label": "Web App", "detail": "PWA", "parent": "", "layer": "experience", "fill": "" },
        { "shape": "rounded", "nodeId": "api", "label": "API Gateway", "detail": "", "parent": "web", "layer": "services", "fill": "" },
        { "shape": "rounded", "nodeId": "auth", "label": "Auth Service", "detail": "", "parent": "api", "layer": "services", "fill": "" },
        { "shape": "rounded", "nodeId": "db", "label": "Database", "detail": "Postgres", "parent": "api", "layer": "data", "fill": "" }
      ]
    },
    {
      "id": "layers",
      "label": "Layers (top → bottom)",
      "type": "blocks",
      "labelledFields": true,
      "showIf": { "source": "visual", "diagramType": "layercake" },
      "help": "Each band of the layercake, stacked in this order. Cards reference a band by its ID.",
      "addMenu": { "field": "kind", "label": "Add layer" },
      "fields": [
        { "id": "kind", "label": "Kind", "type": "select", "default": "layer", "options": [ { "value": "layer", "label": "Layer", "repeatable": true } ] },
        { "id": "layerId", "label": "ID", "type": "text", "placeholder": "e.g. experience" },
        { "id": "label", "label": "Label", "type": "text", "placeholder": "e.g. Experience" },
        { "id": "bandFill", "label": "Band colour", "type": "color", "default": "#efefef" }
      ],
      "default": [
        { "kind": "layer", "layerId": "experience", "label": "Experience", "bandFill": "#90ebcd" },
        { "kind": "layer", "layerId": "services", "label": "Services", "bandFill": "#bff1ea" },
        { "kind": "layer", "layerId": "data", "label": "Data", "bandFill": "#efefef" }
      ]
    },
    {
      "id": "arrows",
      "label": "Flow arrows",
      "type": "blocks",
      "labelledFields": true,
      "showIf": { "source": "visual" },
      "help": "In process diagrams these arrows ARE the flow (they lay out the steps). In org/layercake they're extra arrows on top of the automatic connectors. From/To reference a card ID (or, in layercake, a layer ID).",
      "fields": [
        { "id": "from", "label": "From (ID)", "type": "text", "placeholder": "card or layer ID" },
        { "id": "to", "label": "To (ID)", "type": "text", "placeholder": "card or layer ID" },
        { "id": "label", "label": "Label", "type": "text", "placeholder": "optional" },
        { "id": "style", "label": "Line", "type": "select", "default": "solid", "options": [ { "value": "solid", "label": "Solid" }, { "value": "dashed", "label": "Dashed" } ] },
        { "id": "color", "label": "Colour", "type": "color", "default": "#0c322c" }
      ],
      "default": []
    },
    { "id": "nodeFill", "label": "Card fill", "type": "color", "default": "#ffffff", "group": "Style" },
    { "id": "nodeStroke", "label": "Card border", "type": "color", "default": "#0c322c", "group": "Style" },
    { "id": "nodeText", "label": "Card text", "type": "color", "default": "#0c322c", "group": "Style" },
    { "id": "edgeColor", "label": "Connectors", "type": "color", "default": "#0c322c", "group": "Style" },
    { "id": "background", "label": "Background", "type": "color", "default": "#ffffff", "group": "Style", "help": "Set to Transparent for a knock-out background." }
  ]
}
