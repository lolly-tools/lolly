{
  "id": "filter-pixel-stretch",
  "name": "Filter: Pixel Stretch",
  "description": "Freeze a photo at a threshold line and smear that column of pixels across the frame — set where it starts, how far it spreads, and which way it runs. Works live.",
  "a11yLabel": "Pixel-stretch smear of the chosen image",
  "version": "1.2.0",
  "engineVersion": "^1.0.0",
  "status": "official",
  "category": "designer",
  "tags": ["photo", "filter", "pixel", "stretch", "smear", "glitch", "distort", "effect"],
  "render": {
    "width": 1080,
    "height": 1080,
    "formats": ["png", "jpg", "webp", "svg", "gif", "webm", "mp4"],
    "actions": ["copy", "download", "save"],
    "video": { "wait": 0, "duration": 5 },
    "liveMaxEdge": 1280
  },
  "hooks": {
    "onInit": true,
    "onInput": true,
    "onFrame": true
  },
  "inputs": [
    {
      "id": "image",
      "label": "Image",
      "type": "asset",
      "assetType": "raster",
      "allowUpload": true,
      "help": "Pick a photo or upload your own. It's processed on your device — the pixels never leave the browser. Or hit “Go live” on the canvas to smear your camera."
    },
    {
      "id": "direction",
      "label": "Direction",
      "type": "select",
      "default": "right",
      "options": [
        { "value": "right", "label": "Stretch right →" },
        { "value": "left",  "label": "Stretch left ←" },
        { "value": "down",  "label": "Stretch down ↓" },
        { "value": "up",    "label": "Stretch up ↑" }
      ],
      "help": "Which way the frozen column of pixels smears across the frame."
    },
    {
      "id": "threshold",
      "label": "Threshold start",
      "type": "number",
      "display": "slider",
      "default": 42,
      "min": 0,
      "max": 100,
      "step": 1,
      "help": "Where the photo freezes and the smear begins — the position of the sampled column along the stretch direction."
    },
    {
      "id": "spread",
      "label": "Spread",
      "type": "number",
      "display": "slider",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 1,
      "help": "How far the smear reaches from the threshold toward the edge. 0 leaves the photo untouched; 100 stretches all the way to the edge."
    },
    {
      "id": "feather",
      "label": "Feather",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "help": "Softens the seam where the photo meets the smear, blending them over a band. 0 keeps a hard edge."
    },
    {
      "id": "hue",
      "label": "Hue",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -180,
      "max": 180,
      "step": 1,
      "help": "Rotate every colour around the wheel."
    },
    {
      "id": "saturation",
      "label": "Saturation",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 100,
      "min": 0,
      "max": 200,
      "step": 1,
      "help": "0 = greyscale · 100 = original · 200 = vivid."
    },
    {
      "id": "lightness",
      "label": "Lightness",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 0,
      "min": -100,
      "max": 100,
      "step": 1,
      "help": "Lift toward white or sink toward black."
    },
    {
      "id": "treatmentColor",
      "label": "Colour treatment",
      "section": "Colour",
      "type": "color",
      "default": "",
      "help": "Blend a colour over the result. Leave empty for none."
    },
    {
      "id": "blendMode",
      "label": "Blend mode",
      "section": "Colour",
      "type": "select",
      "default": "multiply",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "multiply", "label": "Multiply" },
        { "value": "screen", "label": "Screen" },
        { "value": "overlay", "label": "Overlay" },
        { "value": "darken", "label": "Darken" },
        { "value": "lighten", "label": "Lighten" },
        { "value": "color-dodge", "label": "Colour dodge" },
        { "value": "color-burn", "label": "Colour burn" },
        { "value": "hard-light", "label": "Hard light" },
        { "value": "soft-light", "label": "Soft light" },
        { "value": "difference", "label": "Difference" },
        { "value": "exclusion", "label": "Exclusion" }
      ],
      "help": "How the treatment colour mixes with the image."
    },
    {
      "id": "treatmentIntensity",
      "label": "Intensity",
      "section": "Colour",
      "type": "number",
      "display": "slider",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 1,
      "help": "Opacity of the colour overlay."
    },
    {
      "id": "imageFraming",
      "label": "Zoom & Position",
      "section": "Position",
      "help": "Zoom scales the photo up; X / Y pan it within the frame (like object-position). Drag a label or type a value.",
      "type": "vector",
      "fields": [
        { "id": "zoom", "label": "Zoom", "min": 100, "max": 400, "step": 1, "default": 100 },
        { "id": "x",    "label": "X",    "min": 0,   "max": 100, "step": 1, "default": 50  },
        { "id": "y",    "label": "Y",    "min": 0,   "max": 100, "step": 1, "default": 50  }
      ]
    },
    { "id": "width",  "label": "Width",  "type": "number", "default": 1080, "min": 1, "max": 8000, "group": "export" },
    { "id": "height", "label": "Height", "type": "number", "default": 1080, "min": 1, "max": 8000, "group": "export" }
  ]
}
