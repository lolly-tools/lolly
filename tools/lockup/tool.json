{
  "id": "lockup",
  "name": "Product Lockup",
  "description": "SUSE product lockups as crisp outlined vectors.",
  "version": "1.1.0",
  "engineVersion": "^1.0.0",
  "status": "experimental",
  "category": "designer",
  "tags": ["lockup", "typography", "product", "brand", "wordmark"],
  "render": {
    "width": 1080,
    "height": 1080,
    "formats": ["svg", "png"],
    "actions": ["copy", "download", "save"]
  },
  "inputs": [
    {
      "id": "name",
      "label": "Product name",
      "type": "text",
      "required": false,
      "default": "Linux Enterprise",
      "help": "The product name, e.g. \"Linux Enterprise\" or \"Rancher Desktop\". Leave blank for just \"SUSE\"."
    },
    {
      "id": "config",
      "label": "Configuration",
      "type": "text",
      "required": false,
      "default": "",
      "help": "Optional qualifier, e.g. \"for SAP\" or \"High Availability\"."
    },
    {
      "id": "lineWidth",
      "label": "Line width",
      "type": "number",
      "display": "slider",
      "min": 256,
      "max": 4000,
      "step": 1,
      "default": 800
    },
    {
      "id": "oneColor",
      "label": "One color",
      "type": "boolean",
      "default": false
    },
    {
      "id": "color",
      "label": "Text color",
      "type": "color",
      "default": "#0c322c"
    },
    {
      "id": "background",
      "label": "Background",
      "type": "color",
      "default": "#ffffff"
    }
  ],
  "capabilities": ["wasm"],
  "hooks": {
    "onInit": true,
    "onInput": true,
    "beforeExport": true,
    "afterExport": true
  }
}
