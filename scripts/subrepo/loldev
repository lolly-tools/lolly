#!/usr/bin/env bash
# loldev ŌĆö one command for developing the lolly monorepo across its lolly-tools
# submodules. Install puts it on your PATH (see `loldev help`). Works from any cwd;
# operates on $LOLLY_ROOT (default ~/Build/lolly, override with the env var).
#
#   loldev gtg [-m "msg"] [--force] [--no-build]
#       "good to go" ŌĆö typecheck + build/validate the catalog for EVERY live
#       profile (gate, see SHIP_TARGETS in config.sh), then commit + push every
#       changed submodule to its own repo AND the parent, to the correct place.
#       No -m ŌåÆ empty commit message. First push after the history rewrite
#       needs --force (once).
#   loldev push [-m "msg"] [--force]   gtg without the catalog rebuild
#   loldev ship [-m "msg"] [--preview] gtg, THEN deploy EVERY SHIP_TARGETS project to
#                                      Vercel uniformly (prod; --preview = preview URLs)
#   loldev status | st                 what's dirty / ahead, per repo
#   loldev build                       build:catalog + validate:catalog
#   loldev previews                    regenerate look/card thumbnails (slow, Playwright) ŌĆö opt-in, run when a tool's look changes
#   loldev verify [--clone]            full post-split build/run verification
#   loldev profile [name] [--copy]     show or switch the content profile (suse / lolly-start):
#                                      rebuilds the tools/ + catalog/ views from the packs
#   loldev pull | up                   pull parent + update all submodules + refresh the profile views
#   loldev dev                         run the web shell (npm run dev:web)
#   loldev cli -- <args>               run a tool headlessly (npm run cli)
#   loldev help

LOLLY_ROOT="${LOLLY_ROOT:-$HOME/Build/lolly}"
SUB="$LOLLY_ROOT/scripts/subrepo"
if [ ! -f "$SUB/config.sh" ]; then
  echo "loldev: can't find $SUB/config.sh ŌĆö set LOLLY_ROOT to your lolly checkout." >&2; exit 1
fi
# shellcheck source=/dev/null
source "$SUB/config.sh"
set +e +u   # interactive resilience ŌĆö keep going across submodules, handle errors inline
cd "$REPO_ROOT" || { echo "loldev: cannot cd $REPO_ROOT" >&2; exit 1; }

usage() { awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "${BASH_SOURCE[0]}"; }

changed_submodules() {
  local p
  while read -r p; do
    [ -n "$(git -C "$p" status --porcelain 2>/dev/null)" ] && echo "$p"
  done < <(subrepo_paths)
}

do_build() {
  phase "­¤öŹ" "Build gate"
  step "type-checking every project"
  npm run --silent typecheck || { err "typecheck failed ŌĆö fix it, or run 'loldev push' to bypass the build gate"; return 1; }
  ok "typecheck passed"

  # build:catalog re-rolls catalog/previews/bundle.json (pure filesystem, no browser).
  # The heavy Playwright card/look render is a separate, opt-in `loldev previews`.
  # Every SHIP_TARGETS profile feeds a live site (bt=suse, lolly-start=lolly-start) ŌĆö
  # validate each one's catalog, not just whichever profile happens to be checked
  # out locally, so a push can't silently break the site we're not developing in.
  local starting; starting="$(cat "$REPO_ROOT/.lolly-profile" 2>/dev/null)"
  local entry name id profile domain seen=()
  for entry in "${SHIP_TARGETS[@]}"; do
    IFS='|' read -r name id profile domain <<<"$entry"
    [[ " ${seen[*]:-} " == *" $profile "* ]] && continue   # dedupe shared profiles
    seen+=("$profile")
    step "building + validating the '$profile' catalog ($domain)"
    node scripts/use-profile.ts "$profile" >/dev/null 2>&1 \
      || { err "profile '$profile' isn't mounted here ŌĆö can't validate $domain before push"; return 1; }
    npm run --silent build:catalog    || { err "build:catalog failed for profile '$profile'";    return 1; }
    npm run --silent validate:catalog || { err "validate:catalog failed for profile '$profile'"; return 1; }
    ok "'$profile' catalog built + validated"
  done
  # Restore the pre-gate profile. If none was set (fresh checkout / no
  # .lolly-profile), the loop above leaves the LAST-iterated SHIP_TARGET
  # (lolly-start) pinned locally ŌĆö that is exactly the stale sticky state that
  # once leaked the blank brand into a lolly.tools deploy. Fall back to
  # $LOLLY_PROFILE, else profiles.json's default, so we never silently pin the
  # blank brand on someone who never chose one.
  local restore="$starting"
  [ -z "$restore" ] && restore="${LOLLY_PROFILE:-$(node -e 'process.stdout.write(require("./profiles.json").default||"")' 2>/dev/null)}"
  [ -n "$restore" ] && node scripts/use-profile.ts "$restore" >/dev/null 2>&1
}

# Pretty end-of-run tally. Reads the PUSHED / FAILED / NOOP globals gtg fills in.
# $1 = elapsed seconds, $2 = headline emoji+verb ("Ō£© Good to go" / "­¤ÜĆ Shipping").
gtg_summary() {
  local secs="$1" head="$2" n=${#PUSHED[@]} f=${#FAILED[@]} x
  echo
  rule
  if [ "$f" -eq 0 ]; then
    printf "  ${c_bold}${c_grn}%s${c_reset}  ${c_gray}┬Ę  %s repo(s) in %ss${c_reset}\n" "$head" "$n" "$secs"
  else
    printf "  ${c_bold}${c_red}Ō£Ś  finished with %s failure(s)${c_reset}  ${c_gray}┬Ę  %ss${c_reset}\n" "$f" "$secs"
  fi
  for x in "${PUSHED[@]}"; do printf "     ${c_grn}Ō¼å${c_reset}  ${c_white}%s${c_reset}\n" "$x"; done
  for x in "${NOOP[@]}";   do printf "     ${c_gray}┬Ę  %s ŌĆö unchanged${c_reset}\n" "$x"; done
  for x in "${FAILED[@]}"; do printf "     ${c_red}Ō£Ś  %s${c_reset}\n" "$x"; done
  rule
}

gtg() {
  local MSG="" FORCE=0 NOBUILD=0 title="loldev gtg" blurb="good to go ┬Ę commit + push every changed repo"
  while [ $# -gt 0 ]; do
    case "$1" in
      -m|--message) shift; MSG="${1:-}" ;;
      -f|--force)   FORCE=1 ;;
      --no-build)   NOBUILD=1; title="loldev push"; blurb="fast lane ┬Ę commit + push, no build gate" ;;
      *) warn "gtg: ignoring '$1'" ;;
    esac; shift
  done

  local start=$SECONDS
  PUSHED=(); FAILED=(); NOOP=()   # globals ŌĆö read back in gtg_summary
  banner "­¤ŹŁ" "$title" "$blurb"

  if [ "$NOBUILD" = 1 ]; then
    phase "ŌÅ®" "Build gate"; info "skipped (push mode)"
  else
    do_build || { err "build failed ŌĆö not pushing"; return 1; }
  fi

  # 1. each changed submodule ŌåÆ its own repo
  phase "­¤ō”" "Submodules"
  local any=0 p repo out
  while read -r p; do
    [ -z "$p" ] && continue
    any=1; repo="$ORG/$(repo_for_path "$p")"
    step "$p  ŌåÆ  $repo"
    git -C "$p" add -A
    if git -C "$p" commit --allow-empty-message -m "$MSG" >/dev/null 2>&1; then
      if out=$(git -C "$p" push 2>&1); then
        ok "pushed $p"; PUSHED+=("$p  ŌåÆ  $repo")
      else
        err "push failed: $p"; printf '%s\n' "$out" | sed "s/^/        ${c_red}Ōöé${c_reset} /"; FAILED+=("$p (push)")
      fi
    else
      warn "$p ŌĆö nothing to commit"; NOOP+=("$p")
    fi
    git add "$p"   # stage the pointer bump in the parent
  done < <(changed_submodules)
  [ "$any" = 0 ] && info "no submodule changes"

  # 2. parent (pointer bumps + parent-owned files) ŌåÆ lolly-tools/lolly
  phase "­¤ī│" "Parent repo"
  git add -A
  if git diff --cached --quiet; then
    info "nothing new to commit"
  else
    git commit --allow-empty-message -m "$MSG" >/dev/null 2>&1 && ok "committed pointer bumps"
  fi
  step "push parent  ŌåÆ  $ORG/lolly"
  if [ "$FORCE" = 1 ]; then out=$(git push --force origin HEAD:main 2>&1); else out=$(git push origin HEAD:main 2>&1); fi
  if [ $? -eq 0 ]; then
    ok "parent pushed"; PUSHED+=("(parent)  ŌåÆ  $ORG/lolly")
  else
    printf '%s\n' "$out" | sed "s/^/        ${c_red}Ōöé${c_reset} /"
    err "parent push rejected ŌĆö the FIRST push after the history rewrite needs:  loldev gtg --force"
    FAILED+=("(parent)")
  fi

  gtg_summary $((SECONDS - start)) "Ō£© Good to go!"
  [ "${#FAILED[@]}" -eq 0 ]   # exit status reflects success/failure
}

# Post-deploy brand assertion. The brand a project actually builds is governed
# ENTIRELY by its Vercel LOLLY_PROFILE env ŌĆö which this toolkit never sets and,
# until now, never checked. A missing/typo'd env silently ships the wrong brand
# to a live domain while ship() still prints a green banner (it once shipped the
# blank brand to lolly.tools). This reads the freshly-deployed domain's catalog
# and FAILS the ship if the live tool set doesn't match the set the target's
# declared profile is supposed to serve. Prod only ŌĆö a preview deploy gets a
# throwaway URL and never updates the domain alias, so there's nothing to assert.
# $1=profile  $2=domain  $3=project id (for the hint).
verify_deploy() {
  local profile="$1" domain="$2" id="$3" expected actual tries=0
  expected="$(node -e 'const p=require("./profiles.json").profiles[process.argv[1]];if(!p)process.exit(3);process.stdout.write(String((require("./"+p.catalog+"/tools/index.json").tools||[]).length))' "$profile" 2>/dev/null)"
  if [ -z "$expected" ]; then
    warn "verify: can't read the expected catalog for profile '$profile' ŌĆö skipping brand assertion for $domain"
    return 0
  fi
  step "verifying $domain is serving the '$profile' brand (expecting $expected tools)"
  while [ "$tries" -lt 6 ]; do
    actual="$(curl -fsS --max-time 30 "https://$domain/catalog/tools/index.json" 2>/dev/null \
      | node -e 'let s="";process.stdin.on("data",c=>s+=c).on("end",()=>{try{process.stdout.write(String((JSON.parse(s).tools||[]).length))}catch(e){process.stdout.write("")}})' 2>/dev/null)"
    [ "$actual" = "$expected" ] && { ok "verify: $domain serving '$profile' ŌĆö $actual tools live"; return 0; }
    tries=$((tries + 1)); sleep 5
  done
  err "verify: $domain shipped the WRONG brand ŌĆö expected profile '$profile' ($expected tools) but the live catalog shows '${actual:-unreadable}' after $tries checks"
  err "  the deploy is live but built the wrong brand. Check this project's LOLLY_PROFILE env:"
  err "    VERCEL_ORG_ID=$VERCEL_TEAM_ID VERCEL_PROJECT_ID=$id npx vercel env ls"
  return 1
}

# ship = gtg (build + commit + push to GitHub) THEN deploy to Vercel ŌĆö EVERY
# project in SHIP_TARGETS, uniformly (currently `bt`ŌåÆlolly.tools/SUSE and
# `lolly-start`ŌåÆlolly.art/blank brand), so `loldev ship` never leaves one site
# stale relative to the other. Uses `npx vercel` (CLI not installed globally) +
# cached auth (andyfitz); VERCEL_ORG_ID/VERCEL_PROJECT_ID env overrides pick the
# target project per deploy without touching the local `.vercel/` link (stays
# pointed at `bt`, e.g. for `vercel dev`). --archive=tgz tarballs the LOCAL tree
# for every target, so submodule content ships and Vercel compiles api/
# functions. The brand each target builds is PINNED per-deploy from SHIP_TARGETS
# via `--build-env LOLLY_PROFILE=<profile>` (repo = source of truth), so the right
# profile ŌĆö and therefore the whole brand: palette, tokens, fonts, tools, catalog ŌĆö
# always lands on the right domain regardless of dashboard/local state; verify_deploy
# then asserts it on the live domain. --preview ŌåÆ preview URLs instead of prod.
ship() {
  local PREVIEW=0 gargs=() a
  for a in "$@"; do [ "$a" = "--preview" ] && PREVIEW=1 || gargs+=("$a"); done
  gtg "${gargs[@]}" || { err "gtg failed ŌĆö not deploying"; return 1; }

  local tgt flags
  if [ "$PREVIEW" = 1 ]; then tgt="PREVIEW"; flags=(); else tgt="PRODUCTION"; flags=(--prod); fi

  local -a SHIPPED=() SFAILED=()
  local entry name id profile domain log rc url line
  for entry in "${SHIP_TARGETS[@]}"; do
    IFS='|' read -r name id profile domain <<<"$entry"
    phase "­¤ÜĆ" "Deploy ŌåÆ Vercel ($name ŌåÆ $domain, $profile ┬Ę $tgt)"
    step "tarballing the local tree + building on Vercel (LOLLY_PROFILE=$profile)"
    log="$(mktemp -t loldev-ship.XXXXXX)"
    # PIN the brand at build-time from SHIP_TARGETS (repo = source of truth). `-b`
    # sets LOLLY_PROFILE for THIS build, so postinstall's use-profile --auto can't
    # fall through to the tarballed sticky file or the `suse` default and build the
    # wrong brand ŌĆö and because the whole brand (palette/tokens/fonts/tools/catalog)
    # is materialised from the profile, pinning it pins ALL of it. Overrides the
    # project's dashboard LOLLY_PROFILE for this deploy; that dashboard var stays as
    # the fallback for Vercel's git-integration auto-deploys, which skip loldev ship.
    # verify_deploy() below still asserts the live domain afterwards (belt + braces).
    VERCEL_ORG_ID="$VERCEL_TEAM_ID" VERCEL_PROJECT_ID="$id" \
      npx --yes vercel deploy "${flags[@]}" --archive=tgz --build-env "LOLLY_PROFILE=$profile" --yes 2>&1 | tee "$log"
    rc=${PIPESTATUS[0]}
    url="$(grep -Eo 'https://[a-zA-Z0-9._~:/?#@!$&%*+=-]+' "$log" | tail -1)"
    rm -f "$log"
    if [ "$rc" -eq 0 ]; then
      ok "shipped $name"
      if [ "$PREVIEW" != 1 ] && ! verify_deploy "$profile" "$domain" "$id"; then
        SFAILED+=("$name ŌåÆ $domain (deployed, but the WRONG brand is live)")
      else
        line="$domain"; [ -n "$url" ] && line="$line  ┬Ę  $url"
        SHIPPED+=("$line")
      fi
    else
      err "vercel deploy failed: $name (exit $rc)"
      SFAILED+=("$name ŌåÆ $domain")
    fi
  done

  echo
  rule
  if [ "${#SFAILED[@]}" -eq 0 ]; then
    printf "  ${c_bold}${c_grn}­¤Äē  Shipped!${c_reset}  ${c_gray}┬Ę  %s site(s) live on Vercel${c_reset}\n" "${#SHIP_TARGETS[@]}"
  else
    printf "  ${c_bold}${c_red}Ō£Ś  %s/%s site(s) failed to deploy${c_reset}\n" "${#SFAILED[@]}" "${#SHIP_TARGETS[@]}"
  fi
  for line in "${SHIPPED[@]}"; do printf "     ${c_cyan}­¤īÉ  %s${c_reset}\n" "$line"; done
  for line in "${SFAILED[@]}"; do printf "     ${c_red}Ō£Ś  %s${c_reset}\n" "$line"; done
  rule
  [ "${#SFAILED[@]}" -eq 0 ]
}

cmd="${1:-help}"; [ $# -gt 0 ] && shift
case "$cmd" in
  gtg)          gtg "$@" ;;
  push)         gtg --no-build "$@" ;;
  ship)         ship "$@" ;;
  status|st)    bash "$SUB/status.sh" ;;
  build)        do_build ;;
  validate)     npm run validate:catalog ;;
  previews)     npm run previews ;;
  verify)       bash "$SUB/verify.sh" "$@" ;;
  profile|brand) node scripts/use-profile.ts "$@" ;;
  pull|up)      git pull --ff-only origin main && git submodule update --init --recursive \
                  && node scripts/use-profile.ts --auto \
                  && ok "synced parent + submodules + profile views" ;;
  dev)          npm run dev:web ;;
  cli)          npm run cli -- "$@" ;;
  help|-h|--help) usage ;;
  *)            err "unknown command: $cmd"; echo; usage; exit 2 ;;
esac
