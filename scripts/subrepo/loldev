#!/usr/bin/env bash
# loldev — one command for developing the lolly monorepo across its lolly-tools
# submodules. Install puts it on your PATH (see `loldev help`). Works from any cwd;
# operates on $LOLLY_ROOT (default ~/Build/lolly, override with the env var).
#
#   loldev gtg [-m "msg"] [--force] [--previews] [--no-build]
#       "good to go" — typecheck + build the catalog (gate), then commit + push every changed
#       submodule to its own repo AND the parent, to the correct place.
#       No -m → empty commit message. First push after the history rewrite
#       needs --force (once).
#   loldev push [-m "msg"] [--force]   gtg without the catalog rebuild
#   loldev ship [-m "msg"] [--preview] gtg, THEN deploy to Vercel (prod; --preview = preview URL)
#   loldev status | st                 what's dirty / ahead, per repo
#   loldev build                       build:catalog + validate:catalog
#   loldev previews                    regenerate look thumbnails (slow, Playwright)
#   loldev verify [--clone]            full post-split build/run verification
#   loldev pull | up                   pull parent + update all submodules
#   loldev dev                         run the web shell (npm run dev:web)
#   loldev cli -- <args>               run a tool headlessly (npm run cli)
#   loldev help

LOLLY_ROOT="${LOLLY_ROOT:-$HOME/Build/lolly}"
SUB="$LOLLY_ROOT/scripts/subrepo"
if [ ! -f "$SUB/config.sh" ]; then
  echo "loldev: can't find $SUB/config.sh — set LOLLY_ROOT to your lolly checkout." >&2; exit 1
fi
# shellcheck source=/dev/null
source "$SUB/config.sh"
set +e +u   # interactive resilience — keep going across submodules, handle errors inline
cd "$REPO_ROOT" || { echo "loldev: cannot cd $REPO_ROOT" >&2; exit 1; }

usage() { awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "${BASH_SOURCE[0]}"; }

changed_submodules() {
  local p
  while read -r p; do
    [ -n "$(git -C "$p" status --porcelain 2>/dev/null)" ] && echo "$p"
  done < <(subrepo_paths)
}

do_build() {  # $1 = run previews? (1/0)
  phase "🔍" "Build gate"
  step "type-checking every project"
  npm run --silent typecheck || { err "typecheck failed — fix it, or run 'loldev push' to bypass the build gate"; return 1; }
  ok "typecheck passed"
  step "building + validating the catalog"
  npm run --silent build:catalog   || { err "build:catalog failed";    return 1; }
  npm run --silent validate:catalog || { err "validate:catalog failed"; return 1; }
  ok "catalog built + validated"
  if [ "${1:-0}" = 1 ]; then
    step "regenerating look previews (slow — Playwright/Chromium)"
    npm run previews && ok "previews regenerated" || warn "previews failed (continuing anyway)"
  fi
}

# Pretty end-of-run tally. Reads the PUSHED / FAILED / NOOP globals gtg fills in.
# $1 = elapsed seconds, $2 = headline emoji+verb ("✨ Good to go" / "🚀 Shipping").
gtg_summary() {
  local secs="$1" head="$2" n=${#PUSHED[@]} f=${#FAILED[@]} x
  echo
  rule
  if [ "$f" -eq 0 ]; then
    printf "  ${c_bold}${c_grn}%s${c_reset}  ${c_gray}·  %s repo(s) in %ss${c_reset}\n" "$head" "$n" "$secs"
  else
    printf "  ${c_bold}${c_red}✗  finished with %s failure(s)${c_reset}  ${c_gray}·  %ss${c_reset}\n" "$f" "$secs"
  fi
  for x in "${PUSHED[@]}"; do printf "     ${c_grn}⬆${c_reset}  ${c_white}%s${c_reset}\n" "$x"; done
  for x in "${NOOP[@]}";   do printf "     ${c_gray}·  %s — unchanged${c_reset}\n" "$x"; done
  for x in "${FAILED[@]}"; do printf "     ${c_red}✗  %s${c_reset}\n" "$x"; done
  rule
}

gtg() {
  local MSG="" FORCE=0 PREVIEWS=0 NOBUILD=0 title="loldev gtg" blurb="good to go · commit + push every changed repo"
  while [ $# -gt 0 ]; do
    case "$1" in
      -m|--message) shift; MSG="${1:-}" ;;
      -f|--force)   FORCE=1 ;;
      --previews)   PREVIEWS=1 ;;
      --no-build)   NOBUILD=1; title="loldev push"; blurb="fast lane · commit + push, no build gate" ;;
      *) warn "gtg: ignoring '$1'" ;;
    esac; shift
  done

  local start=$SECONDS
  PUSHED=(); FAILED=(); NOOP=()   # globals — read back in gtg_summary
  banner "🍭" "$title" "$blurb"

  if [ "$NOBUILD" = 1 ]; then
    phase "⏩" "Build gate"; info "skipped (push mode)"
  else
    do_build "$PREVIEWS" || { err "build failed — not pushing"; return 1; }
  fi

  # 1. each changed submodule → its own repo
  phase "📦" "Submodules"
  local any=0 p repo out
  while read -r p; do
    [ -z "$p" ] && continue
    any=1; repo="$ORG/$(repo_for_path "$p")"
    step "$p  →  $repo"
    git -C "$p" add -A
    if git -C "$p" commit --allow-empty-message -m "$MSG" >/dev/null 2>&1; then
      if out=$(git -C "$p" push 2>&1); then
        ok "pushed $p"; PUSHED+=("$p  →  $repo")
      else
        err "push failed: $p"; printf '%s\n' "$out" | sed "s/^/        ${c_red}│${c_reset} /"; FAILED+=("$p (push)")
      fi
    else
      warn "$p — nothing to commit"; NOOP+=("$p")
    fi
    git add "$p"   # stage the pointer bump in the parent
  done < <(changed_submodules)
  [ "$any" = 0 ] && info "no submodule changes"

  # 2. parent (pointer bumps + parent-owned files) → lolly-tools/lolly
  phase "🌳" "Parent repo"
  git add -A
  if git diff --cached --quiet; then
    info "nothing new to commit"
  else
    git commit --allow-empty-message -m "$MSG" >/dev/null 2>&1 && ok "committed pointer bumps"
  fi
  step "push parent  →  $ORG/lolly"
  if [ "$FORCE" = 1 ]; then out=$(git push --force origin HEAD:main 2>&1); else out=$(git push origin HEAD:main 2>&1); fi
  if [ $? -eq 0 ]; then
    ok "parent pushed"; PUSHED+=("(parent)  →  $ORG/lolly")
  else
    printf '%s\n' "$out" | sed "s/^/        ${c_red}│${c_reset} /"
    err "parent push rejected — the FIRST push after the history rewrite needs:  loldev gtg --force"
    FAILED+=("(parent)")
  fi

  gtg_summary $((SECONDS - start)) "✨ Good to go!"
  [ "${#FAILED[@]}" -eq 0 ]   # exit status reflects success/failure
}

# ship = gtg (build + commit + push to GitHub) THEN deploy to Vercel (project `bt`,
# linked via .vercel/). Uses `npx vercel` (CLI not installed globally) + cached auth
# (andyfitz). --archive=tgz tarballs the LOCAL tree, so submodule content ships and
# Vercel compiles api/ functions. --preview → a preview URL instead of prod.
ship() {
  local PREVIEW=0 gargs=() a
  for a in "$@"; do [ "$a" = "--preview" ] && PREVIEW=1 || gargs+=("$a"); done
  gtg "${gargs[@]}" || { err "gtg failed — not deploying"; return 1; }

  local tgt flags log rc url
  if [ "$PREVIEW" = 1 ]; then tgt="PREVIEW"; flags=(); else tgt="PRODUCTION → lolly.tools"; flags=(--prod); fi
  phase "🚀" "Deploy → Vercel (bt, $tgt)"
  step "tarballing the local tree + building on Vercel"
  log="$(mktemp -t loldev-ship.XXXXXX)"
  npx --yes vercel deploy "${flags[@]}" --archive=tgz --yes 2>&1 | tee "$log"
  rc=${PIPESTATUS[0]}
  url="$(grep -Eo 'https://[a-zA-Z0-9._~:/?#@!$&%*+=-]+' "$log" | tail -1)"
  rm -f "$log"

  echo
  rule
  if [ "$rc" -eq 0 ]; then
    printf "  ${c_bold}${c_grn}🎉  Shipped!${c_reset}  ${c_gray}·  live on Vercel${c_reset}\n"
    [ -n "$url" ] && printf "     ${c_cyan}🌐  %s${c_reset}\n" "$url"
    [ "$PREVIEW" = 0 ] && printf "     ${c_cyan}🌐  https://lolly.tools${c_reset}\n"
  else
    printf "  ${c_bold}${c_red}✗  vercel deploy failed${c_reset}  ${c_gray}(exit %s)${c_reset}\n" "$rc"
  fi
  rule
  [ "$rc" -eq 0 ]
}

cmd="${1:-help}"; [ $# -gt 0 ] && shift
case "$cmd" in
  gtg)          gtg "$@" ;;
  push)         gtg --no-build "$@" ;;
  ship)         ship "$@" ;;
  status|st)    bash "$SUB/status.sh" ;;
  build)        do_build 0 ;;
  validate)     npm run validate:catalog ;;
  previews)     npm run previews ;;
  verify)       bash "$SUB/verify.sh" "$@" ;;
  pull|up)      git pull --ff-only origin main && git submodule update --init --recursive && ok "synced parent + submodules" ;;
  dev)          npm run dev:web ;;
  cli)          npm run cli -- "$@" ;;
  help|-h|--help) usage ;;
  *)            err "unknown command: $cmd"; echo; usage; exit 2 ;;
esac
