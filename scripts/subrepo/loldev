#!/usr/bin/env bash
# loldev — one command for developing the lolly monorepo across its lolly-tools
# submodules. Install puts it on your PATH (see `loldev help`). Works from any cwd;
# operates on $LOLLY_ROOT (default ~/Build/lolly, override with the env var).
#
#   loldev gtg [-m "msg"] [--force] [--previews] [--no-build]
#       "good to go" — build the catalog, then commit + push every changed
#       submodule to its own repo AND the parent, to the correct place.
#       No -m → empty commit message. First push after the history rewrite
#       needs --force (once).
#   loldev push [-m "msg"] [--force]   gtg without the catalog rebuild
#   loldev ship [-m "msg"] [--preview] gtg, THEN deploy to Vercel (prod; --preview = preview URL)
#   loldev status | st                 what's dirty / ahead, per repo
#   loldev build                       build:catalog + validate:catalog
#   loldev previews                    regenerate look thumbnails (slow, Playwright)
#   loldev verify [--clone]            full post-split build/run verification
#   loldev pull | up                   pull parent + update all submodules
#   loldev dev                         run the web shell (npm run dev:web)
#   loldev cli -- <args>               run a tool headlessly (npm run cli)
#   loldev help

LOLLY_ROOT="${LOLLY_ROOT:-$HOME/Build/lolly}"
SUB="$LOLLY_ROOT/scripts/subrepo"
if [ ! -f "$SUB/config.sh" ]; then
  echo "loldev: can't find $SUB/config.sh — set LOLLY_ROOT to your lolly checkout." >&2; exit 1
fi
# shellcheck source=/dev/null
source "$SUB/config.sh"
set +e +u   # interactive resilience — keep going across submodules, handle errors inline
cd "$REPO_ROOT" || { echo "loldev: cannot cd $REPO_ROOT" >&2; exit 1; }

usage() { awk 'NR>1 && /^#/ {sub(/^# ?/,""); print; next} NR>1 {exit}' "${BASH_SOURCE[0]}"; }

changed_submodules() {
  local p
  while read -r p; do
    [ -n "$(git -C "$p" status --porcelain 2>/dev/null)" ] && echo "$p"
  done < <(subrepo_paths)
}

do_build() {  # $1 = run previews? (1/0)
  say "build catalog"
  npm run --silent build:catalog || { err "build:catalog failed"; return 1; }
  npm run --silent validate:catalog || { err "validate:catalog failed"; return 1; }
  ok "catalog built + validated"
  if [ "${1:-0}" = 1 ]; then warn "previews (slow — Playwright/Chromium)"; npm run previews || warn "previews failed (continuing)"; fi
}

gtg() {
  local MSG="" FORCE=0 PREVIEWS=0 NOBUILD=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -m|--message) shift; MSG="${1:-}" ;;
      -f|--force)   FORCE=1 ;;
      --previews)   PREVIEWS=1 ;;
      --no-build)   NOBUILD=1 ;;
      *) warn "gtg: ignoring '$1'" ;;
    esac; shift
  done

  [ "$NOBUILD" = 1 ] || do_build "$PREVIEWS" || { err "build failed — not pushing"; return 1; }

  # 1. each changed submodule → its own repo
  local any=0 p
  while read -r p; do
    [ -z "$p" ] && continue
    any=1
    say "$p  →  $ORG/$(repo_for_path "$p")"
    git -C "$p" add -A
    if git -C "$p" commit --allow-empty-message -m "$MSG" >/dev/null; then
      git -C "$p" push && ok "pushed $p" || err "push failed: $p"
    else
      warn "$p: nothing to commit"
    fi
    git add "$p"   # stage the pointer bump in the parent
  done < <(changed_submodules)
  [ "$any" = 0 ] && info "no submodule changes"

  # 2. parent (pointer bumps + parent-owned files) → lolly-tools/lolly
  git add -A
  if git diff --cached --quiet; then
    info "parent: nothing new to commit"
  else
    git commit --allow-empty-message -m "$MSG" >/dev/null && ok "parent committed"
  fi
  say "push parent  →  $ORG/lolly"
  if [ "$FORCE" = 1 ]; then git push --force origin HEAD:main; else git push origin HEAD:main; fi
  if [ $? -eq 0 ]; then ok "parent pushed"; else
    err "parent push rejected — the FIRST push after the history rewrite needs:  loldev gtg --force"
  fi
}

# ship = gtg (build + commit + push to GitHub) THEN deploy to Vercel (project `bt`,
# linked via .vercel/). Uses `npx vercel` (CLI not installed globally) + cached auth
# (andyfitz). --archive=tgz tarballs the LOCAL tree, so submodule content ships and
# Vercel compiles api/ functions. --preview → a preview URL instead of prod.
ship() {
  local PREVIEW=0 gargs=() a
  for a in "$@"; do [ "$a" = "--preview" ] && PREVIEW=1 || gargs+=("$a"); done
  gtg "${gargs[@]}" || { err "gtg failed — not deploying"; return 1; }
  echo
  if [ "$PREVIEW" = 1 ]; then
    say "deploy → Vercel (bt, PREVIEW)"
    npx --yes vercel deploy --archive=tgz --yes && ok "preview deployed" || err "vercel deploy failed"
  else
    say "deploy → Vercel (bt, PRODUCTION → lolly.tools)"
    npx --yes vercel deploy --prod --archive=tgz --yes && ok "production deployed" || err "vercel deploy failed"
  fi
}

cmd="${1:-help}"; [ $# -gt 0 ] && shift
case "$cmd" in
  gtg)          gtg "$@" ;;
  push)         gtg --no-build "$@" ;;
  ship)         ship "$@" ;;
  status|st)    bash "$SUB/status.sh" ;;
  build)        do_build 0 ;;
  validate)     npm run validate:catalog ;;
  previews)     npm run previews ;;
  verify)       bash "$SUB/verify.sh" "$@" ;;
  pull|up)      git pull --ff-only origin main && git submodule update --init --recursive && ok "synced parent + submodules" ;;
  dev)          npm run dev:web ;;
  cli)          npm run cli -- "$@" ;;
  help|-h|--help) usage ;;
  *)            err "unknown command: $cmd"; echo; usage; exit 2 ;;
esac
