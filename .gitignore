# Throwaway test fixtures (e.g. logo-wall live-test logos copied into public/)
_testlogos/
shells/web/public/_testlogos/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/



# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# future plans
plans/
# secrets copy kept locally (also covered by plans/ above — explicit for safety)
plans/secrets.md

# local scratch working files (untracked going forward; history retained)
scratch/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
.env
.env.*
!.env.example

# Catalog signing key material — generated by `node scripts/sign-catalog.ts
# --gen-key`. The private key is a .pem (also covered below); ignore the whole
# directory so neither half slips into history — the public JWK is pinned in
# deployment config (e.g. VITE_CATALOG_PUBLIC_KEY_JWK), never committed.
keys/

# CA root key material — generated locally by services/ca/scripts/gen-root.mjs.
# The private key (lolly-root-key.pem) is the ONLY secret that matters and must
# NEVER be committed; the public cert lives as a string in
# shells/web/src/ca-root.js, not as a tracked .pem. Ignore every .pem so no root
# material can slip into history. (Verified: no .pem is tracked today.)
*.pem

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist
.output

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp directory
.temp

# Sveltekit cache directory
.svelte-kit/

# vitepress build output
**/.vitepress/dist

# vitepress cache directory
**/.vitepress/cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# Firebase cache directory
.firebase/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# pnpm
.pnpm-store

# yarn v3
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Vercel CLI / MCP project link
.vercel

# Vite files
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/

# macOS
.DS_Store
**/.DS_Store

# Web build output (Vercel/CI regenerate via `npm run build:web`)
shells/web/dist/

# Scoped Chromium for the CLI's Tier-B raster path (`lolly install-browser`).
# Never committed — a plain `npm install` pulls no browser.
.browsers/

# Tool preview thumbnails — generated via `npm run previews`, but COMMITTED so a
# plain git-based web deploy ships them (otherwise build:web drops them and the
# gallery falls back to bare tiles). A committed tools/<id>/card.svg|png still
# overrides per tool. Regenerate + commit when a tool's look changes.

# Generated docs/info site (rebuilt at deploy via `npm run build:info`)
# NOTE: mascots/ are committed assets — build:info does NOT regenerate them, so keep them tracked.
shells/web/public/info/*.html
shells/web/public/info/logos/
shells/web/public/info/og/

# Per-tool social-share stubs (HTML, no rasterizer needed) — regenerated by
# scripts/build-tool-og.ts in build:web/dev:web. The per-tool CARD images are NOT
# here: they live committed in catalog/og/ (resvg won't run on the Vercel build, so
# the bytes must ship with the repo — same reason catalog/previews/ is committed).
shells/web/public/t/

# Per-view social-share stubs (/d, /v, /c, /p, /profile) — regenerated by
# scripts/build-view-og.ts in build:web/dev:web. Like the tool stubs above, the CARD
# images are committed instead (catalog/og/views/) so they ship on a resvg-less deploy.
shells/web/public/view/

# Rust / Tauri native builds (regenerated by `npm run build:desktop` / `build:android` / `build:ios`)
target/
**/src-tauri/target/
**/src-tauri/gen/
shells/tauri-desktop/dist/
shells/tauri-mobile/dist/

# Lolly batch / export artifacts
lolly-batch-*/
lolly-batch-*.zip
lolly-url-screenshot-*/
lolly-url-screenshot-*.zip

# Generated Vercel MCP function bundle (scripts/build-mcp-fn.ts) — COMMITTED so it's
# present at Vercel function-detection time; buildCommand regenerates it fresh each deploy.
api/mcp/[...path].js.map
api/ca/[...path].js.map
.env*
