{
  "name": "@lolly-tools/core",
  "version": "0.1.0",
  "description": "The Lolly tool-author contract: HostV1 capability-bridge types, the tool.json manifest schema + validator, an in-memory mock host for testing, and typed authoring helpers. Depend on this to build a Lolly tool without the platform monorepo.",
  "license": "MPL-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./host-v1": "./src/host-v1.ts",
    "./schema/tool.schema.json": "./schema/tool.schema.json",
    "./schema/asset.schema.json": "./schema/asset.schema.json",
    "./schema/asset-ref.schema.json": "./schema/asset-ref.schema.json"
  },
  "files": [
    "src",
    "schema",
    "README.md"
  ],
  "keywords": [
    "lolly",
    "lolly-tools",
    "tool-sdk",
    "capability-bridge",
    "content-generation"
  ],
  "scripts": {
    "test": "node --test \"test/**/*.test.ts\"",
    "typecheck": "tsc -p ."
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
