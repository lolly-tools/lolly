{
  "name": "@lolly-tools/node-shell",
  "version": "0.1.0",
  "description": "Shared Node-shell plumbing for the Lolly CLI and TUI: repo-root resolution, the scoped headless-Chromium launcher, the web-shell render tier, the resvg raster fast path, and the export Content-Credentials payload builder. One implementation so the terminal shells can never drift.",
  "license": "MPL-2.0",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./repo-root": "./src/repo-root.ts",
    "./browsers": "./src/browsers.ts",
    "./webshell-render": "./src/webshell-render.ts",
    "./raster": "./src/raster.ts",
    "./c2pa-opts": "./src/c2pa-opts.ts",
    "./text": "./src/text.ts",
    "./render-integrity": "./src/render-integrity.ts",
    "./url-capture": "./src/url-capture.ts"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc -p ."
  },
  "dependencies": {
    "@lolly-tools/core": "*",
    "@lolly/engine": "*",
    "@resvg/resvg-js": "^2.6.2",
    "harfbuzzjs": "^1.4.0",
    "playwright-core": "^1.49.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
