{
  "id": "layout-studio",
  "name": "Layout Studio",
  "version": "1.4.1",
  "engineVersion": "^1.12.0",
  "status": "community",
  "category": "designer",
  "tags": ["canvas", "layout", "wysiwyg", "editor", "poster", "compose", "design", "free-form", "import", "figma", "penpot", "pdf", "ai", "illustrator", "idml", "indesign", "adobe"],
  "featured": {
    "order": 1,
    "blurb": "Free-form layouts on an open canvas"
  },
  "examples": [
    {"label":"Launch card · paper","values":{"background":"#f3f5f8","boxes":[{"id":"card","kind":"box","x":80,"y":80,"w":920,"h":920,"rot":0,"shape":"rounded","bg":"#ffffff","radius":32},{"id":"accent","kind":"box","x":600,"y":-320,"w":780,"h":780,"rot":24,"shape":"ellipse","bg":"#d1e7ff"},{"id":"head","kind":"text","x":150,"y":560,"w":780,"h":240,"rot":0,"shape":"rect","text":"Design once,\n{#4f84ba|ship everywhere}","fg":"#0e1217","fontSize":68,"align":"left","valign":"top","weight":"600","font":"sans","lineHeight":1.12},{"id":"sub","kind":"text","x":150,"y":840,"w":780,"h":90,"rot":0,"shape":"rect","text":"Templates, tokens and tools — one canvas.","fg":"#5c646d","fontSize":30,"align":"left","valign":"top","weight":"400","font":"sans","lineHeight":1.3}]}},
    {"label":"Quote · ink","values":{"background":"#0e1217","boxes":[{"id":"accent","kind":"box","x":-260,"y":620,"w":720,"h":720,"rot":-18,"shape":"ellipse","bg":"#082a49"},{"id":"quote","kind":"text","x":120,"y":260,"w":840,"h":420,"rot":0,"shape":"rect","text":"“Constraints are the fastest route to a consistent brand.”","fg":"#f3f5f8","fontSize":58,"align":"left","valign":"top","weight":"500","font":"sans","lineHeight":1.15},{"id":"attr","kind":"text","x":120,"y":740,"w":840,"h":60,"rot":0,"shape":"rect","text":"{#80afe1|— The starter template}","fg":"#a3acb5","fontSize":28,"align":"left","valign":"top","weight":"600","font":"sans","lineHeight":1.12}]}},
    {"label":"Split · slate","values":{"background":"#ffffff","boxes":[{"id":"left","kind":"box","x":0,"y":0,"w":540,"h":1080,"rot":0,"shape":"rect","bg":"#336699"},{"id":"right","kind":"box","x":540,"y":0,"w":540,"h":1080,"rot":0,"shape":"rect","bg":"#eef6ff"},{"id":"head","kind":"text","x":72,"y":170,"w":410,"h":300,"rot":0,"shape":"rect","text":"Your brand,\n{#a9cff6|your rules}","fg":"#ffffff","fontSize":58,"align":"left","valign":"top","weight":"600","font":"sans","lineHeight":1.12},{"id":"body","kind":"text","x":72,"y":540,"w":410,"h":180,"rot":0,"shape":"rect","text":"Every export stays on-palette.","fg":"#d1e7ff","fontSize":28,"align":"left","valign":"top","weight":"300","font":"sans","lineHeight":1.3},{"id":"cta","kind":"box","x":72,"y":770,"w":270,"h":84,"rot":0,"shape":"pill","bg":"#0e1217"},{"id":"ctatext","kind":"text","x":72,"y":792,"w":270,"h":44,"rot":0,"shape":"rect","text":"Get started →","fg":"#ffffff","fontSize":26,"align":"center","valign":"top","weight":"600","font":"sans","lineHeight":1.12},{"id":"dot","kind":"box","x":700,"y":300,"w":220,"h":220,"rot":45,"shape":"rounded","radius":48,"bg":"#4f84ba"}]}}
  ],
  "render": {
    "width": 1080,
    "height": 1080,
    "formats": ["png", "svg", "pdf", "jpg", "webp"],
    "actions": ["copy", "download", "save", "share"],
    "layout": "editor",
    "transparentBg": true,
    "printMarks": false
  },
  "hooks": { "onInit": true, "onInput": true, "beforeExport": true },
  "inputs": [
    {
      "id": "background",
      "type": "color",
      "label": "Canvas background",
      "default": "#f3f5f8"
    },
    {
      "id": "boxes",
      "type": "blocks",
      "label": "Boxes",
      "labelledFields": true,
      "addMenu": { "field": "kind", "label": "Add box" },
      "canvas": {
        "idField": "id",
        "xField": "x",
        "yField": "y",
        "wField": "w",
        "hField": "h",
        "rotationField": "rot",
        "shapeField": "shape",
        "radiusField": "radius",
        "fillField": "bg",
        "opacityField": "opacity",
        "imageField": "image",
        "imgPosField": "imgpos",
        "textField": "text",
        "textColorField": "fg",
        "fontSizeField": "fontSize",
        "alignField": "align",
        "valignField": "valign",
        "weightField": "weight",
        "fontField": "font",
        "lineHeightField": "lineHeight",
        "trackingField": "tracking",
        "ligaturesField": "ligatures",
        "alternatesField": "alternates",
        "padField": "pad",
        "fitField": "fit",
        "blendField": "blend",
        "groupField": "group",
        "clipField": "clip",
        "shadowField": "shadow",
        "shadowColorField": "shadowColor",
        "shadowXField": "shadowX",
        "shadowYField": "shadowY",
        "shadowBlurField": "shadowBlur",
        "minSize": 8,
        "import": { "formats": ["svg", "penpot", "pdf", "ai", "idml"] },
        "addKinds": [
          { "id": "box", "label": "Box", "seed": { "kind": "box", "bg": "#4f84ba", "shape": "rounded", "text": "" } },
          { "id": "text", "label": "Text", "seed": { "kind": "text", "bg": "", "shape": "rect", "text": "Text", "fg": "#0e1217", "fontSize": 64, "valign": "top", "font": "sans", "lineHeight": 1.12 } },
          { "id": "image", "label": "Image", "seed": { "kind": "image", "bg": "#e1e5ea", "shape": "rounded", "fit": "contain", "text": "" } },
          { "id": "lottie", "label": "Animation", "seed": { "kind": "image", "bg": "", "shape": "rounded", "fit": "contain", "text": "" } },
          { "id": "video", "label": "Video", "seed": { "kind": "image", "bg": "", "shape": "rounded", "fit": "contain", "text": "" } }
        ]
      },
      "fields": [
        { "id": "id", "type": "text" },
        {
          "id": "kind",
          "type": "select",
          "label": "Kind",
          "default": "box",
          "options": [
            { "value": "box", "label": "Box", "repeatable": true },
            { "value": "text", "label": "Text", "repeatable": true },
            { "value": "image", "label": "Image", "repeatable": true }
          ]
        },
        { "id": "x", "type": "number", "label": "X", "default": 120 },
        { "id": "y", "type": "number", "label": "Y", "default": 120 },
        { "id": "w", "type": "number", "label": "Width", "default": 320, "min": 1 },
        { "id": "h", "type": "number", "label": "Height", "default": 200, "min": 1 },
        { "id": "rot", "type": "number", "label": "Rotation", "default": 0, "min": -180, "max": 180 },
        {
          "id": "shape",
          "type": "select",
          "label": "Shape",
          "default": "rect",
          "options": [
            { "value": "rect", "label": "Rectangle" },
            { "value": "rounded", "label": "Rounded" },
            { "value": "pill", "label": "Pill" },
            { "value": "ellipse", "label": "Ellipse" }
          ]
        },
        { "id": "radius", "type": "number", "label": "Corner radius", "default": 16, "min": 0, "showIf": { "shape": "rounded" } },
        { "id": "bg", "type": "color", "label": "Fill", "default": "#4f84ba" },
        { "id": "opacity", "type": "number", "label": "Opacity", "default": 100, "min": 0, "max": 100, "display": "slider" },
        { "id": "image", "type": "asset", "label": "Image, animation or video", "assetType": "any", "allowUpload": true, "help": "A photo, logo, SVG, GIF, Lottie animation, or a short video (MP4/WebM). Animations and video play live on the canvas; still exports (PNG/SVG/PDF) capture the current frame." },
        {
          "id": "fit",
          "type": "select",
          "label": "Image fit",
          "default": "contain",
          "options": [
            { "value": "contain", "label": "Contain (fit inside)" },
            { "value": "cover", "label": "Cover (crop to fill)" },
            { "value": "fill", "label": "Stretch" }
          ]
        },
        {
          "id": "blend",
          "type": "select",
          "label": "Blend mode",
          "default": "normal",
          "options": [
            { "value": "normal", "label": "Normal" },
            { "value": "multiply", "label": "Multiply" },
            { "value": "screen", "label": "Screen" },
            { "value": "overlay", "label": "Overlay" },
            { "value": "darken", "label": "Darken" },
            { "value": "lighten", "label": "Lighten" },
            { "value": "color-dodge", "label": "Colour dodge" },
            { "value": "color-burn", "label": "Colour burn" },
            { "value": "hard-light", "label": "Hard light" },
            { "value": "soft-light", "label": "Soft light" },
            { "value": "difference", "label": "Difference" },
            { "value": "exclusion", "label": "Exclusion" },
            { "value": "hue", "label": "Hue" },
            { "value": "saturation", "label": "Saturation" },
            { "value": "color", "label": "Colour" },
            { "value": "luminosity", "label": "Luminosity" }
          ]
        },
        { "id": "text", "type": "text", "label": "Text", "default": "", "multilineFor": ["box", "text", "image"], "rows": 3, "help": "Rich text: **bold**, *italic* / _italic_, and lines starting with - or • become bullets." },
        { "id": "fg", "type": "color", "label": "Text colour", "default": "#0e1217" },
        { "id": "fontSize", "type": "number", "label": "Text size", "default": 48, "min": 4 },
        {
          "id": "align",
          "type": "select",
          "label": "Align",
          "default": "center",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Centre" },
            { "value": "right", "label": "Right" }
          ]
        },
        {
          "id": "valign",
          "type": "select",
          "label": "Vertical",
          "default": "middle",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "middle", "label": "Middle" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "id": "weight",
          "type": "select",
          "label": "Weight",
          "default": "500",
          "help": "How heavy the heaviest cut is depends on the font — the mono stack is capped at Extrabold (800).",
          "options": [
            { "value": "100", "label": "Thin" },
            { "value": "200", "label": "Extra light" },
            { "value": "300", "label": "Light" },
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semibold" },
            { "value": "700", "label": "Bold" },
            { "value": "800", "label": "Extrabold" },
            { "value": "900", "label": "Black" }
          ]
        },
        {
          "id": "font",
          "type": "select",
          "label": "Font",
          "default": "sans",
          "options": [
            { "value": "sans", "label": "Brand sans" },
            { "value": "mono", "label": "Mono" }
          ]
        },
        { "id": "lineHeight", "type": "number", "label": "Line height", "default": 1.12, "min": 0.7, "max": 3, "step": 0.05 },
        { "id": "tracking", "type": "number", "label": "Kerning", "default": 0, "min": -100, "max": 400, "step": 0.5, "help": "Uniform letter spacing (tracking) in px. Baked into the vector export." },
        { "id": "ligatures", "type": "boolean", "label": "Ligatures", "default": true, "help": "Standard ligatures (fi, fl, …). Applies on screen and in the outlined SVG/PDF/EMF export." },
        { "id": "alternates", "type": "boolean", "label": "Stylistic alternates", "default": false, "help": "OpenType stylistic alternates (salt), where the font provides them." },
        { "id": "group", "type": "text", "label": "Group", "default": "" },
        { "id": "clip", "type": "text", "label": "Clip to", "default": "" },
        { "id": "pad", "type": "number", "label": "Text padding", "default": 8, "min": 0 },
        {
          "id": "shadow",
          "type": "select",
          "label": "Shadow",
          "default": "none",
          "help": "What the drop shadow applies to: the box outline, the text, or the visible content (image alpha). Raster export only — SVG/PDF flatten it.",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "box", "label": "Box" },
            { "value": "text", "label": "Text" },
            { "value": "content", "label": "Content" }
          ]
        },
        { "id": "shadowColor", "type": "color", "label": "Shadow colour", "default": "#00000055" },
        { "id": "shadowX", "type": "number", "label": "Shadow X", "default": 0, "min": -300, "max": 300 },
        { "id": "shadowY", "type": "number", "label": "Shadow Y", "default": 0, "min": -300, "max": 300 },
        { "id": "shadowBlur", "type": "number", "label": "Shadow blur", "default": 10, "min": 0, "max": 300 },
        {
          "id": "imgpos",
          "type": "select",
          "label": "Image position",
          "default": "center",
          "help": "Which edge or corner the image is anchored to — where a contained image sits inside the box, or which part of a cover-cropped image stays in frame. Honoured on screen and in PNG/SVG/PDF export.",
          "options": [
            { "value": "left top", "label": "Top left" },
            { "value": "center top", "label": "Top" },
            { "value": "right top", "label": "Top right" },
            { "value": "left center", "label": "Left" },
            { "value": "center", "label": "Centre" },
            { "value": "right center", "label": "Right" },
            { "value": "left bottom", "label": "Bottom left" },
            { "value": "center bottom", "label": "Bottom" },
            { "value": "right bottom", "label": "Bottom right" }
          ]
        }
      ],
      "default": []
    }
  ]
}
