{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node --experimental-strip-types ../../docs/build.ts && node --experimental-strip-types ../../scripts/build-tool-og.ts && npm run build",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www\\.lolly\\.tools" }],
      "destination": "https://lolly.tools/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": ".*lolly\\.(art|ad|bot|codes|design|free|gallery|graphics|ing|ink|is|media|sh|style|to|work)" }],
      "destination": "https://lolly.tools/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/t/:id", "destination": "/t/:id.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
