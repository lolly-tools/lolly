{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.vercel",
      "!**/.browsers",
      "!**/*.min.js",
      "!package-lock.json",
      "!sbom.cdx.json",
      "!tools",
      "!catalog",
      "!api",
      "!shells/web/public",
      "!shells/*/bridge-overrides",
      "!shells/chrome-extension",
      "!shells/*/src-tauri",
      "!**/vite.config.js",
      "!**/*.config.js"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noDescendingSpecificity": "off",
        "useTemplate": "off"
      },
      "complexity": {
        "noImportantStyles": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off"
      }
    }
  },
  "assist": {
    "actions": {
      "source": { "organizeImports": "on" }
    }
  }
}
