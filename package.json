{
  "name": "lolly",
  "version": "0.1.0",
  "private": true,
  "description": "Constraint-first, template-driven on-brand asset generation for SUSE.",
  "license": "MPL-2.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "engine",
    "shells/web",
    "shells/cli"
  ],
  "scripts": {
    "dev:web": "node --experimental-strip-types scripts/dev-web.ts",
    "build:web": "npm run build:info && node --experimental-strip-types scripts/build-tool-og.ts && npm --workspace shells/web run build",
    "build:info": "node --experimental-strip-types docs/build.ts",
    "test": "node --experimental-strip-types --test \"tests/**/*.test.js\" \"tests/**/*.test.ts\" \"shells/web/src/**/*.test.js\" \"shells/web/src/**/*.test.ts\"",
    "build:catalog": "node --experimental-strip-types scripts/build-catalog-index.ts && node --experimental-strip-types scripts/checksum-assets.ts",
    "validate:catalog": "node --experimental-strip-types scripts/validate-catalog.ts",
    "previews": "node --experimental-strip-types scripts/build-previews.ts",
    "build:sbom": "node --experimental-strip-types scripts/build-sbom.ts",
    "build:licenses": "node --experimental-strip-types scripts/build-licenses.ts",
    "cli": "node --experimental-strip-types shells/cli/bin/brand-tool.js",
    "dev:desktop": "cd shells/tauri-desktop && npm run dev",
    "build:desktop": "cd shells/tauri-desktop && npm run build",
    "dev:android": "cd shells/tauri-mobile && npm run dev:android",
    "dev:ios": "cd shells/tauri-mobile && npm run dev:ios",
    "build:android": "cd shells/tauri-mobile && npm run build:android",
    "build:ios": "cd shells/tauri-mobile && npm run build:ios",
    "typecheck": "tsc -p engine && tsc -p shells/web && tsc -p shells/web/tsconfig.node.json && tsc -p shells/web/tsconfig.tests.json && tsc -p shells/cli && tsc -p tests && tsc -p scripts"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.20.0",
    "playwright": "^1.49.0",
    "typescript": "~5.9"
  }
}
